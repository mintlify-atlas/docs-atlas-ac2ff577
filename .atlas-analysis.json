  "keyFeatures": [
    "Batch worktree creation for parallel development",
    "Multi-agent workflow support (Claude Code, Command Code, Cursor)",
    "Status dashboard with git metrics",
    "Smart cleanup of merged worktrees",
    "One-command merge and cleanup",
    "Interactive management with search",
    "Configurable defaults and editor integration",
    "Auto dependency installation"
  ],
  "publicApiSurface": [
    "gwt [names...] - Create worktrees",
    "gwt -y, --yes - Fast mode with defaults",
    "gwt -x, --no-editor - Skip editor",
    "gwt ls, list - List worktrees",
    "gwt rm, remove - Remove worktrees",
    "gwt status, st - Show worktree status",
    "gwt clean - Remove merged worktrees",
    "gwt clean -a, --all - Remove all worktrees",
    "gwt merge <name> - Merge and cleanup",
    "gwt config - Manage configuration",
    "gwt config reset - Reset to defaults"
  ]
